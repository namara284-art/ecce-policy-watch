{
  "name": "ecce-policy-watch",
  "version": "0.1.0",
  "private": true,
  "description": "Global ECCE Policy Watch — daily and monthly Early Childhood Care & Education policy intelligence reports, powered by a Claude agent.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "agent:generate": "tsx agent/generate-reports.ts",
    "agent:monthly": "tsx agent/generate-reports.ts --type monthly",
    "digest:daily": "tsx scripts/send-digests.ts --cadence daily",
    "digest:weekly": "tsx scripts/send-digests.ts --cadence weekly",
    "digest:monthly": "tsx scripts/send-digests.ts --cadence monthly"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
