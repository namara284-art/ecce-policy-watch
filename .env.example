# ---- Supabase (optional for local dev) ----
# If these are not set, the site falls back to bundled seed reports so you can
# run `npm run dev` with zero configuration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-side only. Used by the agent to write reports and
# by API routes that need elevated access. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Email (Resend) — Phase 2 ----
# Without RESEND_API_KEY, confirmation/digest emails are logged (dry run) so the
# flows work locally. Set it to actually send.
RESEND_API_KEY=
# Verified sender, e.g. "ECCE Policy Watch <reports@yourdomain.org>".
ECCE_FROM_EMAIL=
# Public base URL used to build confirm/unsubscribe links in emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Claude agent ----
# Used by agent/generate-reports.ts to produce the policy reports.
ANTHROPIC_API_KEY=

# Model selection (sensible defaults baked into the agent).
# Daily passes run high-volume; monthly synthesis favours quality.
ECCE_DAILY_MODEL=claude-sonnet-4-6
ECCE_MONTHLY_MODEL=claude-opus-4-8
